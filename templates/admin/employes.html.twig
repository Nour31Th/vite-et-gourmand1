{% extends 'base.html.twig' %}

{% block title %}Gestion employés — Vite & Gourmand{% endblock %}

{% block body %}

<div style="background:var(--brun);padding:20px;text-align:center">
    <h1 style="font-family:'Montserrat',sans-serif;font-size:30px;font-weight:700;color:#fff">Gestion des employés</h1>
</div>

<section style="padding:32px 80px;background:var(--bgclair)">
    <div class="d-flex gap-2 mb-4">
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary btn-sm">Commandes</a>
        <a href="{{ path('app_admin_employes') }}" class="btn btn-brun btn-sm">Employés</a>
        <a href="{{ path('app_admin_stats') }}" class="btn btn-outline-secondary btn-sm">Statistiques</a>
        <a href="{{ path('app_admin_creer_employe') }}" class="btn btn-vert btn-sm ms-auto">+ Créer un employé</a>
    </div>

    {% for employe in employes %}
    <div style="background:#fff;border-radius:8px;padding:16px;margin-bottom:12px;border:.5px solid #e0ddd5">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div style="font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:var(--brun)">
                    {{ employe.prenom }} {{ employe.nom }}
                </div>
                <div style="font-family:'Lexend',sans-serif;font-size:12px;color:#6B6B5A">{{ employe.email }}</div>
            </div>
            <div class="d-flex align-items-center gap-3">
                {% if employe.actif %}
                <span style="background:#d1fae5;color:#065f46;font-size:11px;padding:3px 10px;border-radius:10px;font-family:'Lexend',sans-serif">Actif</span>
                {% else %}
                <span style="background:#fee2e2;color:#991b1b;font-size:11px;padding:3px 10px;border-radius:10px;font-family:'Lexend',sans-serif">Inactif</span>
                {% endif %}
                <form method="post" action="{{ path('app_admin_toggle_employe', {id: employe.id}) }}">
                    <button type="submit" class="btn btn-outline-secondary btn-sm" style="font-size:12px">
                        {% if employe.actif %}Désactiver{% else %}Réactiver{% endif %}
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% else %}
    <p style="color:#6B6B5A;text-align:center">Aucun employé.</p>
    {% endfor %}
</section>

{% endblock %}