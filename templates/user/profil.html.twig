{% extends 'base.html.twig' %}

{% block title %}Mon profil — Vite & Gourmand{% endblock %}

{% block body %}

<div style="background:var(--beige);padding:20px;text-align:center">
    <h1 style="font-family:'Montserrat',sans-serif;font-size:36px;font-weight:700;color:var(--brun)">
        Mon profil
    </h1>
</div>

<section style="padding:48px 80px;background:var(--bgclair)">
    <div class="row g-4">
        <div class="col-md-3">
            <div style="background:#fff;border-radius:8px;padding:16px;border:.5px solid #e0ddd5">
                <div style="text-align:center;padding:16px 0;border-bottom:.5px solid #e0ddd5;margin-bottom:12px">
                    <div style="width:60px;height:60px;border-radius:50%;background:var(--beige);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:var(--brun);margin:0 auto 8px">
                        {{ user.prenom|first }}{{ user.nom|first }}
                    </div>
                    <div style="font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:var(--brun)">{{ user.prenom }} {{ user.nom }}</div>
                </div>
                <nav>
                    <a href="{{ path('app_user_dashboard') }}" style="display:block;padding:8px 12px;border-radius:6px;font-size:13px;color:var(--brun);text-decoration:none;margin-bottom:4px">
                        Mes commandes
                    </a>
                    <a href="{{ path('app_user_profil') }}" style="display:block;padding:8px 12px;border-radius:6px;font-size:13px;color:var(--brun);text-decoration:none;background:var(--bgclair);font-weight:700;margin-bottom:4px">
                        Mon profil
                    </a>
                    <a href="{{ path('app_logout') }}" style="display:block;padding:8px 12px;border-radius:6px;font-size:13px;color:#dc2626;text-decoration:none;margin-top:8px;border-top:.5px solid #e0ddd5;padding-top:12px">
                        Déconnexion
                    </a>
                </nav>
            </div>
        </div>

        <div class="col-md-9">
            <div style="background:#fff;border-radius:8px;padding:24px;border:.5px solid #e0ddd5">
                <h2 style="font-family:'Poppins',sans-serif;font-size:20px;font-weight:600;color:var(--brun);margin-bottom:20px">Mes informations</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Prénom</label>
                        <input type="text" class="form-control" value="{{ user.prenom }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Nom</label>
                        <input type="text" class="form-control" value="{{ user.nom }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Email</label>
                        <input type="email" class="form-control" value="{{ user.email }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">GSM</label>
                        <input type="text" class="form-control" value="{{ user.gsm }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-8">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Adresse</label>
                        <input type="text" class="form-control" value="{{ user.adresse }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-4">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Code postal</label>
                        <input type="text" class="form-control" value="{{ user.codePostal }}" readonly style="background:var(--bgclair)">
                    </div>
                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:var(--brun)">Ville</label>
                        <input type="text" class="form-control" value="{{ user.ville }}" readonly style="background:var(--bgclair)">
                    </div>
                </div>
                <div class="mt-3">
                    <p style="font-size:12px;color:#6B6B5A">Pour modifier vos informations, contactez-nous à contact@viteetgourmand.fr</p>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}