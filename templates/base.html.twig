<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Vite & Gourmand{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Poppins:wght@400;600&family=Lato:wght@400;700&family=Roboto:wght@700&family=Lexend:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
    <style>
        :root { --beige:#C4A882; --terre:#C4693A; --vert:#5C7A5C; --brun:#2C2B1A; --bgclair:#F5F2EC; }
        body { font-family:'Lato',sans-serif; color:#1A1A1A; }
        .navbar-brand { font-family:'Montserrat',sans-serif; font-weight:700; color:var(--brun) !important; }
        .nav-link { font-family:'Lato',sans-serif; color:var(--brun) !important; }
        .nav-link.active { color:var(--vert) !important; font-weight:700; border-bottom:2px solid var(--vert); }
        .btn-vert { background:var(--vert); color:#fff; font-family:'Roboto',sans-serif; font-weight:700; min-height:44px; border:none; }
        .btn-terre { background:var(--terre); color:#fff; font-family:'Roboto',sans-serif; font-weight:700; min-height:44px; border:none; }
        .btn-brun { background:var(--brun); color:#fff; font-family:'Roboto',sans-serif; font-weight:700; min-height:44px; border:none; }
        footer { background:var(--brun); color:#9A9A7A; }
        footer h5 { color:var(--beige); font-family:'Lato',sans-serif; font-size:11px; text-transform:uppercase; letter-spacing:0.8px; }
        footer a { color:#9A9A7A; text-decoration:none; }
        footer a:hover { color:var(--beige); }
    </style>
</head>
<body>

<a href="#main" class="visually-hidden-focusable">Aller au contenu principal</a>

<nav class="navbar navbar-expand-lg bg-white border-bottom" style="height:68px" aria-label="Navigation principale">
    <div class="container-xl px-4">
        <a class="navbar-brand" href="{{ path('app_home') }}">
    <a class="navbar-brand" href="{{ path('app_home') }}">
    <img src="{{ asset('images/logo.svg') }}" 
         alt="Vite et Gourmand" 
         style="height:65px;width:auto">
</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-label="Ouvrir le menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav mx-auto gap-3">
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}" href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_menu' %}active{% endif %}" href="#">Nos menus</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Vos avis</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Aide</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}" href="#">Contact</a>
                </li>
            </ul>
            <div class="d-flex align-items-center gap-2">
                {% if app.user %}
                    <a href="#" class="btn btn-vert btn-sm px-3">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary btn-sm">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-vert btn-sm px-3">Connexion</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<main id="main">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>

<footer class="py-4 mt-5">
    <div class="container-xl px-4">
        <div class="row g-4">
            <div class="col-lg-3">
                <div style="font-family:'Montserrat',sans-serif;font-weight:700;color:var(--beige);margin-bottom:8px">Vite &amp; Gourmand</div>
                <p style="font-size:12px">Bordeaux depuis 1999<br>contact@viteetgourmand.fr</p>
            </div>
            <div class="col-lg-2">
                <h5>Horaires</h5>
                <p style="font-size:11px">Lun : Fermé</p>
                <p style="font-size:11px">Mar : Fermé</p>
                <p style="font-size:11px">Mer–Dim : 11h–15h / 18h–23h</p>
            </div>
            <div class="col-lg-2">
                <h5>À propos</h5>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Qui sommes-nous ?</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Nos menus</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Liste allergènes</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Les avis</a>
            </div>
            <div class="col-lg-2">
                <h5>Informations</h5>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Mentions légales</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">FAQ</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">CGV</a>
                <a href="#" style="font-size:12px;display:block;line-height:2.2">Politique de confidentialité</a>
            </div>
            <div class="col-lg-3">
                <h5>Newsletter</h5>
                <form action="#" method="post" class="d-flex gap-2">
                    <input type="email" class="form-control form-control-sm" placeholder="Votre email" aria-label="Email newsletter">
                    <button type="submit" class="btn btn-terre btn-sm">OK</button>
                </form>
            </div>
        </div>
        <hr style="border-color:#3a3928;margin:20px 0 10px">
        <div class="d-flex justify-content-between" style="font-size:10px">
            <span>© 2026 Vite &amp; Gourmand — Tous droits réservés</span>
            <span>Bordeaux, France</span>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>